# Optional: custom names for each Govee H5075 sensor.
# Copy this file to ".env" in the project root to override the built-in defaults.
# Format: <device_name>=<custom_name>   (blank lines and #comments ignored)
# If .env is absent, collector.js uses these same defaults from code.

GVH5075_1098=downstairs
GVH5075_A7A8=garage
GVH5075_C375=upstairs
